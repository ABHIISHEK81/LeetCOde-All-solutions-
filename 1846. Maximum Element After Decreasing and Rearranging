//  1846. Maximum Element After Decreasing and Rearranging  //



class Solution(object):
    def maximumElementAfterDecrementingAndRearranging(self, arr):
        """
        :type arr: List[int]
        :rtype: int
        """
        arr.sort()
        prev = 1
        arr[0] = 1

        for i in range(1, len(arr)):
            arr[i] = min(arr[i], prev+1)
            prev = arr[i]

        return prev    

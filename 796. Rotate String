//  796. Rotate String  //




class Solution(object):
    def rotateString(self, s, goal):
        """
        :type s: str
        :type goal: str
        :rtype: bool
        """
        if len(s) != len(goal):
            return False

        target = s[0]

        for i, char in enumerate(goal):
            if char == target:
                if s == goal[i:] + goal[:i]:
                    return True
        return False                              

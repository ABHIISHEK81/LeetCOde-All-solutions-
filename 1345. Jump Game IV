//  1345. Jump Game IV  //



class Solution(object):
    def minJumps(self, arr):
        """
        :type arr: List[int]
        :rtype: int
        """
        n = len(arr)
        if n == 1:
            return 0
            
        visited = [False] * n
        
        occurence = defaultdict(set)
        for i, val in enumerate(arr):
            occurence[val].add(i)
        
        queue = deque([(0, 0)])
        visited[0] = True

        while queue:
            i, jumps = queue.popleft()
            
            if i == n - 1:
                return jumps
            
            if i > 0 and not visited[i-1]:
                visited[i-1] = True
                queue.append((i - 1, jumps + 1))
                
            if i < n - 1 and not visited[i+1]:
                visited[i+1] = True
                queue.append((i + 1, jumps + 1))
            for j in occurence[arr[i]]:
                if not visited[j]:
                    visited[j] = True
                    queue.append((j, jumps + 1))
            
            occurence[arr[i]].clear()

        return -1

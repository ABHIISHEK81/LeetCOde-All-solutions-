//  3600. Maximize Spanning Tree Stability with Upgrades  //


class Solution(object):
    def maxStability(self, n, edges, k):
        """
        :type n: int
        :type edges: List[List[int]]
        :type k: int
        :rtype: int
        """

        parent = list(range(n))

        def find(x):
            while parent[x] != x:
                parent[x] = parent[parent[x]]
                x = parent[x]
            return x

        def union(a, b):
            pa, pb = find(a), find(b)
            if pa == pb:
                return False
            parent[pa] = pb
            return True

        def can(stability):

            for i in range(n):
                parent[i] = i

            used = 0
            upgrades = 0
            optional = []

            # handle must edges
            for u, v, s, must in edges:
                if must == 1:
                    if s < stability:
                        return False
                    if not union(u, v):   # cycle check
                        return False
                    used += 1
                else:
                    optional.append((u, v, s))

            normal = []
            upgrade = []

            for u, v, s in optional:
                if s >= stability:
                    normal.append((u, v))
                elif s * 2 >= stability:
                    upgrade.append((u, v))

            for u, v in normal:
                if used == n - 1:
                    break
                if union(u, v):
                    used += 1

            for u, v in upgrade:
                if used == n - 1:
                    break
                if upgrades == k:
                    break
                if union(u, v):
                    used += 1
                    upgrades += 1

            return used == n - 1

        left = 0
        right = max(e[2] for e in edges) * 2
        ans = -1

        while left <= right:
            mid = (left + right) // 2

            if can(mid):
                ans = mid
                left = mid + 1
            else:
                right = mid - 1

        return ans

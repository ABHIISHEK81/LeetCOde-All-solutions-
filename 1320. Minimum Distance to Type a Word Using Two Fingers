//  1320. Minimum Distance to Type a Word Using Two Fingers  //




class Solution(object):
    def minimumDistance(self, word):
        """
        :type word: str
        :rtype: int
        """
        def dist(a, b):
            if a == -1 or b == -1:
                return 0
            ax, ay = divmod(a, 6)
            bx, by = divmod(b, 6)
            return abs(ax - bx) + abs(ay - by)
        
        dp = [0] * 26
        total = 0
        
        for i in range(1, len(word)):
            prev = ord(word[i-1]) - ord('A')
            curr = ord(word[i]) - ord('A')
            
            cost = dist(prev, curr)
            total += cost
            
            new_dp = dp[:]
            
            for j in range(26):
                new_dp[prev] = max(new_dp[prev],
                                   dp[j] + cost - dist(j, curr))
            
            dp = new_dp
        
        return total - max(dp)

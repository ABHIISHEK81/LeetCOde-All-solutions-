//  3534. Path Existence Queries in a Graph II  //



class Solution(object):
    def pathExistenceQueries(self, n, nums, maxDiff, queries):
        """
        :type n: int
        :type nums: List[int]
        :type maxDiff: int
        :type queries: List[List[int]]
        :rtype: List[int]
        """
      
        order = sorted((nums[i], i) for i in range(n))
        values = [x[0] for x in order]

    
        pos = [0] * n
        for i in range(n):
            pos[order[i][1]] = i

     
        comp = [0] * n
        cid = 0
        for i in range(1, n):
            if values[i] - values[i - 1] > maxDiff:
                cid += 1
            comp[i] = cid

        far = [0] * n
        r = 0
        for i in range(n):
            while r + 1 < n and values[r + 1] - values[i] <= maxDiff:
                r += 1
            far[i] = r

    
        LOG = (n).bit_length()
        up = [far]
        for _ in range(1, LOG):
            prev = up[-1]
            curr = [0] * n
            for i in range(n):
                curr[i] = prev[prev[i]]
            up.append(curr)

        ans = []

        for u, v in queries:
            if u == v:
                ans.append(0)
                continue

            pu = pos[u]
            pv = pos[v]

            if pu > pv:
                pu, pv = pv, pu

            if comp[pu] != comp[pv]:
                ans.append(-1)
                continue

            steps = 0
            cur = pu

            for k in range(LOG - 1, -1, -1):
                nxt = up[k][cur]
                if nxt < pv:
                    cur = nxt
                    steps += 1 << k

            ans.append(steps + 1)

        return ans

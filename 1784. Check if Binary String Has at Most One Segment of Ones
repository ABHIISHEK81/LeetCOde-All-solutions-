// 1784. Check if Binary String Has at Most One Segment of Ones  //




class Solution(object):
    def checkOnesSegment(self, s):
        """
        :type s: str
        :rtype: bool
        """
        i=1;
        while(i<len(s) and s[i]==s[i-1]):
            i+=1;
        while(i<len(s)):
            if(s[i]=="1"):
                return False;
            i+=1
        return True       

//  3558. Number of Ways to Assign Edge Weights I  //



class Solution(object):
    def assignEdgeWeights(self, edges):
        """
        :type edges: List[List[int]]
        :rtype: int
        """
        adj = defaultdict(list)
        for i,j in edges:
            adj[i].append(j)
            adj[j].append(i)
            
        def Treeheight(root,prev):
            if not root:return 0

            res = 0
            for nei in adj[root]:
                if nei==prev:continue
                res = max(res,1+Treeheight(nei,root))
            return res
        height = Treeheight(1,1)
   
        MOD = 10**9 + 7
    
        fact = [1] * (height + 1)
        inv_fact = [1] * (height + 1)
        
        for i in range(2, height + 1):
            fact[i] = (fact[i-1] * i) % MOD
        
        inv_fact[height] = pow(fact[height], MOD-2, MOD)
        for i in range(height-1, 0, -1):
            inv_fact[i] = (inv_fact[i+1] * (i+1)) % MOD
        
        res = 0
        for i in range(1,height+1):
            total = i + (height-i)*2
            if total%2==1:
                res = (res+fact[height] * inv_fact[i] % MOD * inv_fact[height-i] % MOD)%MOD
        return res

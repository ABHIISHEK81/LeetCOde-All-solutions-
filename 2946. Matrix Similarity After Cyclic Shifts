//  2946. Matrix Similarity After Cyclic Shifts  //



class Solution(object):
    def areSimilar(self, mat, k):
        """
        :type mat: List[List[int]]
        :type k: int
        :rtype: bool
        """
        m,n = len(mat),len(mat[0])

        shift =  k % n

        for i in range(m):
            for j in range(n):

                if i % 2 == 0:
                    if mat[i][j] != mat[i][(j + shift) % n]:
                        return False
                else:
                   if mat[i][j] != mat[i][(j - shift + n) % n]:
                        return False

                
        return True

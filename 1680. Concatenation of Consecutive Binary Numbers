//  1680. Concatenation of Consecutive Binary Numbers  //



class Solution(object):
    def concatenatedBinary(self, n):
        """
        :type n: int
        :rtype: int
        """
        res = 0
        mod = 10**9 + 7
        for i in range(1, n + 1):
            res = ((res << i.bit_length()) | i) % mod
        return res

//  1833. Maximum Ice Cream Bars  //



class Solution(object):
    def maxIceCream(self, costs, coins):
        """
        :type costs: List[int]
        :type coins: int
        :rtype: int
        """
        costs.sort()
        ans = 0
        for cost in costs:
            if cost > coins:
                break
            ans += 1
            coins -= cost
        return ans       

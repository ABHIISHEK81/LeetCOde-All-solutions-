//  3474. Lexicographically Smallest Generated String   //



class Solution(object):
    def generateString(self, str1, str2):
        """
        :type str1: str
        :type str2: str
        :rtype: str
        """
        n, m, L = len(str1), len(str2), len(str1) + len(str2) - 1
        res, forced = [''] * L, [False] * L

        for i in range(n):
            if str1[i] == 'T':
                for j, c in enumerate(str2):
                    pos = i + j
                    if res[pos] == '':
                        res[pos], forced[pos] = c, True
                    elif res[pos] != c:
                        return ""

        for i in range(L):
            if res[i] == '':
                res[i] = 'a'

        for i in range(n):
            if str1[i] == 'F' and all(res[i + j] == str2[j] for j in range(m)):
                modified = False
                for j in range(m - 1, -1, -1):
                    pos = i + j
                    if not forced[pos]:  
                        for c in range(ord(res[pos]) + 1, ord('z') + 1):
                            if chr(c) != str2[j]:
                                res[pos] = chr(c)
                                modified = True
                                break
                        if modified:
                            break
                if not modified:
                    return ""

        return "".join(res)

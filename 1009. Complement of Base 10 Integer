//  1009. Complement of Base 10 Integer   //



class Solution(object):
    def bitwiseComplement(self, n):
        """
        :type n: int
        :rtype: int
        """
        if n == 0:
            return 1
        
        bits = len(bin(n)) - 2
        mask = (1 << bits) - 1
        
        return mask ^ n

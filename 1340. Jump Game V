//   1340. Jump Game V  //



class Solution(object):
    def maxJumps(self, arr, d):
        """
        :type arr: List[int]
        :type d: int
        :rtype: int
        """
        n = len(arr)
        memo = {}

        def dp(i):
            if i in memo:
                return memo[i]
            
            res = 1
            for j in range(i + 1, min(i + d + 1, n)):
                if arr[i] <= arr[j]: break 
                res = max(res, 1 + dp(j))
            
            for j in range(i - 1, max(i - d - 1, -1), -1):
                if arr[i] <= arr[j]: break  
                res = max(res, 1 + dp(j))
                
            memo[i] = res
            return res

        return max(dp(i) for i in range(n))

//  788. Rotated Digits  //




class Solution(object):
    def rotatedDigits(self, n):
        """
        :type n: int
        :rtype: int
        """
        count = 0
        for i in range(1, n + 1):
            if self.isGood(i):
                count += 1
        return count

    def isGood(self, n):
        hasChanged = False
        while n > 0:
            digit = n % 10
            if digit == 3 or digit == 4 or digit == 7:
                return False
            if digit == 2 or digit == 5 or digit == 6 or digit == 9:
                hasChanged = True
            n //= 10
        return hasChanged        

//   1752. Check if Array Is Sorted and Rotated  //



class Solution(object):
    def check(self, nums):
        """
        :type nums: List[int]
        :rtype: bool
        """
        n = len(nums)
        breaking_point = 0 
        for i in range(n):
            if nums[i] > nums[(i+1) % n]:
                breaking_point += 1
        return breaking_point <= 1
